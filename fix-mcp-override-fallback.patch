+import { beforeAll, beforeEach, describe, expect, it, vi } from 'vitest';
+
+// Regression test for: MCP server toggle flips from "on" to "off" right after
+// the first message in a brand-new chat triggers conversation creation.
+//
+// Root cause: once `activeConversation` exists, `getMcpServerOverride` only
+// looked at `activeConversation.mcpServerOverrides`, and never fell back to
+// the global `mcpServers[i].enabled` default when that array had no entry
+// for the server -- even though a freshly created conversation intentionally
+// has no per-conversation overrides seeded (see `createConversation`).
+
+vi.mock('$app/navigation', () => ({
+	goto: vi.fn()
+}));
+
+vi.mock('$app/environment', () => ({
+	browser: false
+}));
+
+vi.mock('svelte-sonner', () => ({
+	toast: { success: vi.fn(), error: vi.fn(), info: vi.fn(), warning: vi.fn() }
+}));
+
+vi.mock('$lib/services/migration.service', () => ({
+	MigrationService: {}
+}));
+
+vi.mock('$lib/services/router.service', () => ({
+	RouterService: { chat: vi.fn(() => '/chat/mock') }
+}));
+
+vi.mock('$lib/stores/settings.svelte', () => ({
+	config: vi.fn(() => ({}))
+}));
+
+const createConversationMock = vi.fn();
+const updateConversationMock = vi.fn();
+
+vi.mock('$lib/services/database.service', () => ({
+	DatabaseService: {
+		createConversation: (...args: unknown[]) => createConversationMock(...args),
+		updateConversation: (...args: unknown[]) => updateConversationMock(...args)
+	}
+}));
+
+const getServersMock = vi.fn();
+const updateServerMock = vi.fn();
+
+vi.mock('$lib/stores/mcp.svelte', () => ({
+	mcpStore: {
+		getServers: (...args: unknown[]) => getServersMock(...args),
+		updateServer: (...args: unknown[]) => updateServerMock(...args)
+	}
+}));
+
+const MCP_SERVER_ON = {
+	id: 'server-on',
+	url: 'http://on.example',
+	enabled: true,
+	requestTimeoutSeconds: 30
+};
+const MCP_SERVER_OFF = {
+	id: 'server-off',
+	url: 'http://off.example',
+	enabled: false,
+	requestTimeoutSeconds: 30
+};
+
+describe('conversationsStore MCP per-chat override fallback', () => {
+	let conversationsStore: (typeof import('$lib/stores/conversations.svelte'))['conversationsStore'];
+
+	beforeAll(async () => {
+		({ conversationsStore } = await import('$lib/stores/conversations.svelte'));
+	}, 120000);
+
+	beforeEach(() => {
+		vi.clearAllMocks();
+		getServersMock.mockReturnValue([MCP_SERVER_ON, MCP_SERVER_OFF]);
+	});
+
+	it('falls back to the global enabled flag before any conversation exists', () => {
+		conversationsStore.activeConversation = null;
+
+		expect(conversationsStore.isMcpServerEnabledForChat(MCP_SERVER_ON.id)).toBe(true);
+		expect(conversationsStore.isMcpServerEnabledForChat(MCP_SERVER_OFF.id)).toBe(false);
+	});
+
+	it('keeps the global default once the first message creates the conversation', async () => {
+		conversationsStore.activeConversation = null;
+
+		// Simulate what DatabaseService.createConversation() returns: a brand-new
+		// conversation with no mcpServerOverrides, exactly as chat.svelte.ts's
+		// sendMessage() triggers on the very first message of a new chat.
+		createConversationMock.mockResolvedValue({
+			id: 'conv-1',
+			name: 'New chat',
+			lastModified: Date.now(),
+			currNode: ''
+		});
+		updateConversationMock.mockResolvedValue(undefined);
+
+		await conversationsStore.createConversation();
+
+		expect(conversationsStore.activeConversation?.id).toBe('conv-1');
+		expect(conversationsStore.activeConversation?.mcpServerOverrides).toBeUndefined();
+
+		// This is the regression: previously this returned false because
+		// getMcpServerOverride() stopped falling back once activeConversation
+		// was non-null, regardless of whether an explicit override existed.
+		expect(conversationsStore.isMcpServerEnabledForChat(MCP_SERVER_ON.id)).toBe(true);
+		expect(conversationsStore.isMcpServerEnabledForChat(MCP_SERVER_OFF.id)).toBe(false);
+	});
+
+	it('an explicit per-chat override still takes precedence over the global default', () => {
+		conversationsStore.activeConversation = {
+			id: 'conv-2',
+			name: 'Existing chat',
+			lastModified: Date.now(),
+			currNode: '',
+			mcpServerOverrides: [{ serverId: MCP_SERVER_ON.id, enabled: false }]
+		};
+		conversationsStore.conversations = [conversationsStore.activeConversation];
+		updateConversationMock.mockResolvedValue(undefined);
+
+		// Explicit override says "off" even though the global default is "on".
+		expect(conversationsStore.isMcpServerEnabledForChat(MCP_SERVER_ON.id)).toBe(false);
+		// The other server has no explicit override, so it still falls back to
+		// its (disabled) global default.
+		expect(conversationsStore.isMcpServerEnabledForChat(MCP_SERVER_OFF.id)).toBe(false);
+
+		const all = conversationsStore.getAllMcpServerOverrides();
+		expect(all).toEqual(
+			expect.arrayContaining([
+				{ serverId: MCP_SERVER_ON.id, enabled: false },
+				{ serverId: MCP_SERVER_OFF.id, enabled: false }
+			])
+		);
+		expect(all).toHaveLength(2);
+	});
+});
