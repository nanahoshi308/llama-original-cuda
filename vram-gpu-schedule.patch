+std::optional<int64_t> server_models::estimate_model_vram(const server_model_meta & meta, const std::string & device_name) {
+    if (const char * fake = std::getenv("LLAMA_TEST_FAKE_MODEL_VRAM")) {
+        try {
+            json vram_map = json::parse(fake);
+            if (vram_map.contains(device_name)) {
+                return vram_map[device_name].get<int64_t>();
+            }
+        } catch (const std::exception & e) {
+            SRV_WRN("estimate_model_vram: failed to parse LLAMA_TEST_FAKE_MODEL_VRAM: %s\n", e.what());
+        }
+        return std::nullopt;
+    }
+
+    try {
+        // apply_to_params(params, handled_keys) treats a non-empty handled_keys as an
+        // *inclusion* filter (see its impl in preset.cpp) - passing just the model/mmproj/
+        // hf-repo keys here, as this used to, meant ctx-size/cache-type-k/cache-type-v/
+        // flash-attn/etc. were silently NOT applied, so the estimate below was computed
+        // against common_params' defaults (n_ctx=0 -> full n_ctx_train, f16 KV cache)
+        // instead of the model's actual configured footprint - wildly overestimating VRAM
+        // need for any model that quantizes its KV cache or caps its context below training
+        // length (i.e. almost every real preset). Apply the whole preset normally instead;
+        // common_models_handler_apply() below still safely resolves hf-repo/mmproj-auto
+        // refs afterward (offline=true so it only maps to an already-cached local path,
+        // never downloads) and is a no-op when the preset already gives a direct model path.
+        common_params params;
+        meta.preset.apply_to_params(params);
+        params.offline = true;
+        common_models_handler handler = common_models_handler_init(params, LLAMA_EXAMPLE_SERVER);
+        common_models_handler_apply(handler, params);
+
+        auto * dev = ggml_backend_dev_by_name(device_name.c_str());
+        if (!dev || params.model.path.empty()) {
+            return std::nullopt;
+        }
+
+        llama_model_params   mparams = common_model_params_to_llama(params);
+        llama_context_params cparams = common_context_params_to_llama(params);
+
+        // probe "this model alone on `device_name`": must explicitly restrict mparams.devices,
+        // since leaving it null auto-enumerates every GPU regardless of split_mode, and main_gpu
+        // would then index into that auto-list rather than a specific device
+        std::vector<ggml_backend_dev_t> devices_arr = { dev, nullptr };
+        mparams.devices      = devices_arr.data();
+        mparams.split_mode   = LLAMA_SPLIT_MODE_NONE;
+        mparams.main_gpu     = 0; // index within devices_arr
+        mparams.n_gpu_layers = -2; // "all"
+
+        std::vector<ggml_backend_dev_t> devs;
+        uint32_t hp_ngl = 0, hp_nct = 0, hp_nex = 0;
+
+        // common_get_device_memory_data() is not thread-safe (it temporarily swaps the global
+        // llama logger callback) and transiently constructs a trial model+context, which
+        // deliberately touches the GPU in this otherwise GPU-free router process - a scoped,
+        // accepted exception to the "router never touches the GPU" rule (see server.cpp)
+        std::lock_guard<std::mutex> fit_lk(fit_mutex);
+        auto dmd = common_get_device_memory_data(
+            params.model.path.c_str(), &mparams, &cparams,
+            devs, hp_ngl, hp_nct, hp_nex, GGML_LOG_LEVEL_ERROR);
+        if (dmd.empty()) {
+            return std::nullopt;
+        }
+        return (int64_t) (dmd[0].model + dmd[0].context + dmd[0].compute);
+    } catch (const std::exception & e) {
+        SRV_WRN("estimate_model_vram: failed for model '%s' on device '%s': %s\n",
+                meta.name.c_str(), device_name.c_str(), e.what());
+        return std::nullopt;
+    }
+}
