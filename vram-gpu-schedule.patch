diff --git a/tools/server/tests/unit/test_router_gpu_schedule.py b/tools/server/tests/unit/test_router_gpu_schedule.py
new file mode 100644
index 0000000..e0df8b0
--- /dev/null
+++ b/tools/server/tests/unit/test_router_gpu_schedule.py
@@ -0,0 +1,269 @@
+import json
+import threading
+import urllib.request
+
+import pytest
+from utils import *
+
+server: ServerProcess
+
+MODEL_A = "ggml-org/tinygemma3-GGUF:Q8_0"
+MODEL_B = "ggml-org/test-model-stories260K:F32"
+
+GB = 1024 * 1024 * 1024
+
+
+@pytest.fixture(autouse=True)
+def create_server():
+    global server
+    server = ServerPreset.router()
+    server.models_gpu_schedule = True
+
+
+def _write_fake_gpus(path: str, free_bytes: int, total_bytes: int = 8 * GB, name: str = "CUDA0") -> None:
+    with open(path, "w") as f:
+        json.dump([{"name": name, "free": free_bytes, "total": total_bytes}], f)
+
+
+def _write_fake_gpus_multi(path: str, gpus: list[dict]) -> None:
+    with open(path, "w") as f:
+        json.dump(gpus, f)
+
+
+def _get_model_status(model_id: str) -> str:
+    res = server.make_request("GET", "/models")
+    assert res.status_code == 200
+    for item in res.body.get("data", []):
+        if item.get("id") == model_id or item.get("model") == model_id:
+            return item["status"]["value"]
+    raise AssertionError(f"Model {model_id} not found in /models response")
+
+
+def _get_model_device(model_id: str) -> str | None:
+    """Read back the --device this model instance was actually spawned with."""
+    res = server.make_request("GET", "/models")
+    assert res.status_code == 200
+    for item in res.body.get("data", []):
+        if item.get("id") == model_id or item.get("model") == model_id:
+            args = item["status"].get("args", [])
+            if "--device" in args:
+                return args[args.index("--device") + 1]
+            return None
+    raise AssertionError(f"Model {model_id} not found in /models response")
+
+
+def _wait_for_model_status(model_id: str, desired: set[str], timeout: int = 60) -> str:
+    deadline = time.time() + timeout
+    last_status = None
+    while time.time() < deadline:
+        last_status = _get_model_status(model_id)
+        if last_status in desired:
+            return last_status
+        time.sleep(1)
+    raise AssertionError(
+        f"Timed out waiting for {model_id} to reach {desired}, last status: {last_status}"
+    )
+
+
+def _load_model_and_wait(model_id: str, timeout: int = 60) -> None:
+    load_res = server.make_request("POST", "/models/load", data={"model": model_id})
+    assert load_res.status_code == 200
+    assert isinstance(load_res.body, dict)
+    assert load_res.body.get("success") is True
+    _wait_for_model_status(model_id, {"loaded"}, timeout=timeout)
+
+
+def test_router_gpu_schedule_loads_when_room(tmp_path, monkeypatch):
+    """A model loads normally when the (fake) GPU reports plenty of free VRAM."""
+    gpus_file = tmp_path / "gpus.json"
+    _write_fake_gpus(str(gpus_file), free_bytes=8 * GB)
+    monkeypatch.setenv("LLAMA_TEST_FAKE_GPUS_FILE", str(gpus_file))
+    monkeypatch.setenv("LLAMA_TEST_FAKE_MODEL_VRAM", json.dumps({"CUDA0": 2 * GB}))
+
+    server.start()
+    _load_model_and_wait(MODEL_A, timeout=120)
+    assert _get_model_status(MODEL_A) == "loaded"
+
+
+def test_router_gpu_schedule_evicts_lru_same_device(tmp_path, monkeypatch):
+    """When the fake GPU no longer has room, loading a 2nd model evicts the idle 1st one."""
+    gpus_file = tmp_path / "gpus.json"
+    _write_fake_gpus(str(gpus_file), free_bytes=8 * GB)
+    monkeypatch.setenv("LLAMA_TEST_FAKE_GPUS_FILE", str(gpus_file))
+    monkeypatch.setenv("LLAMA_TEST_FAKE_MODEL_VRAM", json.dumps({"CUDA0": 2 * GB}))
+
+    server.start()
+    _load_model_and_wait(MODEL_A, timeout=120)
+    assert _get_model_status(MODEL_A) == "loaded"
+
+    # simulate the GPU becoming nearly full (e.g. from real usage growing) - not enough
+    # room left for a fresh 2 GiB model, but enough once idle model A is evicted
+    _write_fake_gpus(str(gpus_file), free_bytes=int(2.2 * GB))
+
+    _load_model_and_wait(MODEL_B, timeout=120)
+    assert _get_model_status(MODEL_B) == "loaded"
+    assert _get_model_status(MODEL_A) == "unloaded"
+
+
+def test_router_gpu_schedule_waits_for_busy_model_before_evicting(tmp_path, monkeypatch):
+    """A model that is mid-inference must finish its response before being evicted."""
+    gpus_file = tmp_path / "gpus.json"
+    _write_fake_gpus(str(gpus_file), free_bytes=8 * GB)
+    monkeypatch.setenv("LLAMA_TEST_FAKE_GPUS_FILE", str(gpus_file))
+    monkeypatch.setenv("LLAMA_TEST_FAKE_MODEL_VRAM", json.dumps({"CUDA0": 2 * GB}))
+
+    server.start()
+    _load_model_and_wait(MODEL_A, timeout=120)
+
+    stream_result: dict = {"content": "", "error": None}
+
+    def _stream_a():
+        try:
+            for data in server.make_stream_request("POST", "/chat/completions", data={
+                "model": MODEL_A,
+                "max_tokens": 400,
+                "messages": [{"role": "user", "content": "tell me a long story"}],
+                "stream": True,
+            }):
+                if data["choices"]:
+                    stream_result["content"] += data["choices"][0]["delta"].get("content") or ""
+        except Exception as e:
+            stream_result["error"] = e
+
+    stream_thread = threading.Thread(target=_stream_a, daemon=True)
+    stream_thread.start()
+    time.sleep(0.5)  # give the stream time to actually start before we try to evict it
+
+    # now make the GPU appear full, forcing model B's load to evict the (busy) model A;
+    # if the scheduler killed A mid-generation instead of waiting, its stream would break
+    _write_fake_gpus(str(gpus_file), free_bytes=int(2.2 * GB))
+    _load_model_and_wait(MODEL_B, timeout=120)
+
+    stream_thread.join(timeout=60)
+    assert stream_result["error"] is None, f"model A's stream failed: {stream_result['error']}"
+    assert len(stream_result["content"]) > 0
+    assert _get_model_status(MODEL_B) == "loaded"
+    assert _get_model_status(MODEL_A) == "unloaded"
+
+
+def test_router_gpu_schedule_fails_when_nothing_fits(tmp_path, monkeypatch):
+    """Loading fails with a clear error when the model doesn't fit on any GPU, even empty."""
+    gpus_file = tmp_path / "gpus.json"
+    _write_fake_gpus(str(gpus_file), free_bytes=1 * GB)  # too small for the model below
+    monkeypatch.setenv("LLAMA_TEST_FAKE_GPUS_FILE", str(gpus_file))
+    monkeypatch.setenv("LLAMA_TEST_FAKE_MODEL_VRAM", json.dumps({"CUDA0": 4 * GB}))
+
+    server.start()
+    load_res = server.make_request("POST", "/models/load", data={"model": MODEL_A})
+    assert load_res.status_code >= 400
+    assert _get_model_status(MODEL_A) == "unloaded"
+
+
+def test_router_gpu_schedule_reevaluates_placement_after_unload(tmp_path, monkeypatch):
+    """A model previously placed on one GPU must be re-surveyed on its next load, not
+    stuck retrying the same device forever.
+
+    Regression test: place_model() used to persist its own placement decision into the
+    model's LLAMA_ARG_DEVICE preset option, which is the *same* option it reads to detect
+    a user's manual --device pin ("never second-guess a manual pin"). After an unload,
+    the next load would see that leftover option, treat it as a manual pin, skip the VRAM
+    survey entirely, and retry the same (now full) device - even if another GPU was free.
+    """
+    gpus_file = tmp_path / "gpus.json"
+    _write_fake_gpus_multi(str(gpus_file), [
+        {"name": "CUDA0", "free": 8 * GB, "total": 8 * GB},
+        {"name": "CUDA1", "free": 8 * GB, "total": 8 * GB},
+    ])
+    monkeypatch.setenv("LLAMA_TEST_FAKE_GPUS_FILE", str(gpus_file))
+    monkeypatch.setenv("LLAMA_TEST_FAKE_MODEL_VRAM", json.dumps({"CUDA0": 2 * GB, "CUDA1": 2 * GB}))
+
+    # MODEL_A (tinygemma3) is multimodal, which place_model() exempts from scheduling
+    # entirely (see the "v1 limitation" check for meta.multimodal) - it never gets a
+    # --device assigned, so it can't exercise this code path. MODEL_B is text-only.
+    server.start()
+    _load_model_and_wait(MODEL_B, timeout=120)
+    assert _get_model_status(MODEL_B) == "loaded"
+    assert _get_model_device(MODEL_B) == "CUDA0"
+
+    unload_res = server.make_request("POST", "/models/unload", data={"model": MODEL_B})
+    assert unload_res.status_code == 200
+    _wait_for_model_status(MODEL_B, {"unloaded"}, timeout=60)
+
+    # CUDA0 (where model B landed the first time) is now full; only CUDA1 has room.
+    # The real GPU underneath still has plenty of room for this tiny test model even
+    # if the router (buggily) keeps re-targeting CUDA0, so a bare status=="loaded"
+    # check can't tell a correct re-placement apart from a stale, never-reconsidered
+    # one - we have to check *which* device it actually landed on.
+    _write_fake_gpus_multi(str(gpus_file), [
+        {"name": "CUDA0", "free": int(0.1 * GB), "total": 8 * GB},
+        {"name": "CUDA1", "free": 8 * GB, "total": 8 * GB},
+    ])
+
+    _load_model_and_wait(MODEL_B, timeout=120)
+    assert _get_model_status(MODEL_B) == "loaded"
+    assert _get_model_device(MODEL_B) == "CUDA1"
+
+
+def test_router_gpu_schedule_estimate_honors_ctx_size(tmp_path, monkeypatch):
+    """The VRAM estimate must reflect the model's actual configured ctx-size (and, by the
+    same code path, cache-type-k/v, flash-attn, etc.), not common_params' defaults (ctx-size
+    unset -> full native training context, f16 KV cache).
+
+    Regression test: estimate_model_vram() called preset.apply_to_params() with a
+    restrictive allow-list (only the model/mmproj/hf-repo resolution keys), and that
+    allow-list is an *inclusion* filter - every other preset option, including ctx-size,
+    was silently never applied. Two presets for the exact same model differing only in
+    ctx-size (16 vs. 16,777,216) were therefore estimated identically, so the absurdly
+    large one was wrongly accepted by the scheduler instead of being rejected up front.
+    """
+    gpus_file = tmp_path / "gpus.json"
+    _write_fake_gpus(str(gpus_file), free_bytes=1 * GB)  # the real GPU has plenty of room;
+    monkeypatch.setenv("LLAMA_TEST_FAKE_GPUS_FILE", str(gpus_file))  # this only caps the *decision*
+    # deliberately NOT setting LLAMA_TEST_FAKE_MODEL_VRAM - the real estimator must run
+
+    # a direct local model path (rather than hf-repo) keeps this test independent of the
+    # cache/download layer - estimate_model_vram() only needs a real, readable GGUF file
+    model_path = tmp_path / "stories260K.gguf"
+    urllib.request.urlretrieve(
+        "https://huggingface.co/ggml-org/models/resolve/main/tinyllamas/stories260K.gguf",
+        model_path,
+    )
+
+    # -fit off: --fit is on by default and would otherwise auto-shrink ctx-size to
+    # whatever fits during both the real load AND (per the patch's own docs) the VRAM
+    # estimate itself, defeating this test by making even an absurd ctx-size "fit"
+    presets_ini = tmp_path / "presets.ini"
+    presets_ini.write_text(
+        f"[story-small-ctx]\n"
+        f"model = {model_path}\n"
+        f"ctx-size = 16\n"
+        f"n-gpu-layers = 99\n"
+        f"fit = false\n"
+        f"\n"
+        f"[story-big-ctx]\n"
+        f"model = {model_path}\n"
+        f"ctx-size = 16777216\n"
+        f"n-gpu-layers = 99\n"
+        f"fit = false\n"
+    )
+    server.models_preset = str(presets_ini)
+    server.server_port = 8091  # avoid colliding with a real llama-router that may be running on 8080
+    # ServerPreset.router() sets a router-level --ctx-size 1024, which (per the docs'
+    # preset precedence rule) overrides any per-model ctx-size in our presets - clear it
+    server.n_ctx = None
+    server.start()
+
+    _load_model_and_wait("story-small-ctx", timeout=120)
+    assert _get_model_status("story-small-ctx") == "loaded"
+
+    unload_res = server.make_request("POST", "/models/unload", data={"model": "story-small-ctx"})
+    assert unload_res.status_code == 200
+    _wait_for_model_status("story-small-ctx", {"unloaded"}, timeout=60)
+
+    # same 1 GiB fake budget as before; only ctx-size differs, by six orders of magnitude
+    load_res = server.make_request("POST", "/models/load", data={"model": "story-big-ctx"})
+    assert load_res.status_code >= 400, (
+        "story-big-ctx was accepted despite needing a ~16M-token KV cache - "
+        "the estimate is ignoring ctx-size again"
+    )
+    assert _get_model_status("story-big-ctx") == "unloaded"
