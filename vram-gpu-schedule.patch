+void server_models::place_model(server_model_meta & meta) {
+    if (!base_params.models_gpu_schedule) {
+        return;
+    }
+
+    // manual placement always wins - never second-guess an explicit --device pin
+    std::string existing_device;
+    if (meta.preset.get_option("LLAMA_ARG_DEVICE", existing_device) && !existing_device.empty()) {
+        return;
+    }
+
+    // CPU-only models are exempt, they have no VRAM cost
+    std::string ngl_str;
+    if (meta.preset.get_option("LLAMA_ARG_N_GPU_LAYERS", ngl_str) && ngl_str == "0") {
+        return;
+    }
+
+    // v1 limitation: the estimate below only covers the base LLM, not a vision/audio projector
+    if (meta.multimodal.inp_vision || meta.multimodal.inp_audio) {
+        return;
+    }
+
+    auto devices = query_gpu_devices(bin_path);
+    if (devices.empty()) {
+        SRV_WRN("place_model: no GPU device info available, falling back to default placement for '%s'\n", meta.name.c_str());
+        return;
+    }
+
+    std::map<std::string, int64_t> candidate;
+    for (const auto & dev : devices) {
+        auto est = estimate_model_vram(meta, dev.name);
+        if (est.has_value()) {
+            candidate[dev.name] = *est;
+        }
+    }
+    if (candidate.empty()) {
+        throw std::runtime_error("failed to estimate VRAM for model '" + meta.name + "' on any device");
+    }
+
+    const int64_t margin = (int64_t) base_params.models_gpu_margin_mb * 1024 * 1024;
+
+    // 1st pass: direct fit, first candidate device (declaration order) with enough headroom wins
+    for (const auto & dev : devices) {
+        auto it = candidate.find(dev.name);
+        if (it == candidate.end()) {
+            continue;
+        }
+        if (dev.free - margin >= it->second) {
+            meta.gpu_device = dev.name;
+            meta.vram_bytes = it->second;
+            meta.preset.set_option(ctx_preset, "LLAMA_ARG_DEVICE", dev.name);
+            return;
+        }
+    }
+
+    // 2nd pass: same-device eviction, LRU-first among idle (non-pinned) models
+    struct evict_candidate {
+        std::string name;
+        int64_t vram_bytes;
+        int64_t last_used;
+    };
+
+    for (const auto & dev : devices) {
+        auto it = candidate.find(dev.name);
+        if (it == candidate.end()) {
+            continue;
+        }
+        const int64_t needed = it->second;
+
+        std::vector<evict_candidate> same_device;
+        {
+            std::lock_guard<std::mutex> lk(mutex);
+            for (const auto & [n, inst] : mapping) {
+                if (inst.meta.gpu_device != dev.name || !inst.meta.is_running()) {
+                    continue;
+                }
+                std::string pin_val;
+                if (inst.meta.preset.get_option(COMMON_ARG_PRESET_PIN, pin_val) && common_arg_utils::is_truthy(pin_val)) {
+                    continue; // never auto-evict a pinned model
+                }
+                same_device.push_back({ n, inst.meta.vram_bytes, inst.meta.last_used });
+            }
+        }
+        std::sort(same_device.begin(), same_device.end(), [](const evict_candidate & a, const evict_candidate & b) {
+            return a.last_used < b.last_used; // LRU first
+        });
+
+        int64_t projected_free = dev.free;
+        std::vector<std::string> to_evict;
+        for (const auto & c : same_device) {
+            if (projected_free - margin >= needed) {
+                break;
+            }
+            projected_free += c.vram_bytes;
+            to_evict.push_back(c.name);
+        }
+        if (projected_free - margin < needed) {
+            continue; // even evicting everything on this device isn't enough, try next GPU
+        }
+
+        auto deadline = std::chrono::steady_clock::now() + std::chrono::seconds(base_params.models_gpu_evict_timeout);
+        for (const auto & evict_name : to_evict) {
+            auto busy = get_busy_counter(evict_name);
+            if (busy) {
+                std::unique_lock<std::mutex> lk(mutex);
+                bool ok = cv.wait_until(lk, deadline, [&busy]() {
+                    return busy->load(std::memory_order_acquire) == 0;
+                });
+                if (!ok) {
