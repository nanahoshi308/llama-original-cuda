+        meta.vram_bytes = needed;
+        meta.preset.set_option(ctx_preset, "LLAMA_ARG_DEVICE", dev.name);
+        return;
+    }
+
+    throw std::runtime_error("model '" + meta.name + "' does not fit on any GPU even after evicting all eligible models");
