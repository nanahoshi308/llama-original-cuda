+// parses the flat JSON array produced by --list-devices-json (and by the
+// LLAMA_TEST_FAKE_GPUS test override, which uses the same shape)
+static std::vector<gpu_device_info> parse_gpu_devices_json(const std::string & text) {
+    std::vector<gpu_device_info> result;
+    json devices = json::parse(text);
+    for (const auto & d : devices) {
+        gpu_device_info info;
+        info.name  = d.value("name", "");
+        info.free  = d.value("free",  (int64_t) 0);
+        info.total = d.value("total", (int64_t) 0);
+        if (!info.name.empty()) {
+            result.push_back(info);
+        }
+    }
+    return result;
+}
+
+// live free/total VRAM per GPU, queried via a short-lived "<bin_path> --list-devices-json"
+// helper subprocess so the long-running router process never has to touch the GPU itself
+// (see the "router server never loads a model and must not touch the GPU" note in server.cpp)
+static std::vector<gpu_device_info> query_gpu_devices(const std::string & bin_path) {
+    // file-based override re-reads on every call, unlike a plain env var (fixed for the whole
+    // process lifetime) - lets tests simulate live free VRAM changing between load attempts
+    // without restarting the router
+    if (const char * fake_file = std::getenv("LLAMA_TEST_FAKE_GPUS_FILE")) {
+        std::ifstream f(fake_file);
+        if (f) {
+            std::stringstream ss;
+            ss << f.rdbuf();
+            try {
+                return parse_gpu_devices_json(ss.str());
+            } catch (const std::exception & e) {
+                SRV_WRN("query_gpu_devices: failed to parse LLAMA_TEST_FAKE_GPUS_FILE: %s\n", e.what());
+                return {};
+            }
+        }
+    }
+
+    if (const char * fake = std::getenv("LLAMA_TEST_FAKE_GPUS")) {
+        try {
+            return parse_gpu_devices_json(fake);
+        } catch (const std::exception & e) {
+            SRV_WRN("query_gpu_devices: failed to parse LLAMA_TEST_FAKE_GPUS: %s\n", e.what());
+            return {};
+        }
+    }
+
+    if (bin_path.empty()) {
+        return {};
+    }
+
+    std::vector<std::string> cmd = { bin_path, "--list-devices-json" };
+    std::vector<char *> argv = to_char_ptr_array(cmd);
+
+    subprocess_s proc;
+    int options = subprocess_option_no_window | subprocess_option_combined_stdout_stderr | subprocess_option_inherit_environment;
+    if (subprocess_create(argv.data(), options, &proc) != 0) {
+        SRV_WRN("query_gpu_devices: failed to spawn '%s --list-devices-json'\n", bin_path.c_str());
+        return {};
+    }
+
+    // watchdog: force-kill the helper if it doesn't exit within a few seconds
+    std::atomic<bool> done{false};
+    std::thread watchdog([&proc, &done]() {
+        for (int i = 0; i < 50 && !done.load(std::memory_order_acquire); ++i) {
+            std::this_thread::sleep_for(std::chrono::milliseconds(100));
+        }
+        if (!done.load(std::memory_order_acquire)) {
+            subprocess_terminate(&proc);
+        }
+    });
+
+    std::string output;
+    FILE * out = subprocess_stdout(&proc);
+    if (out) {
+        std::vector<char> buf(64 * 1024);
+        while (fgets(buf.data(), (int) buf.size(), out) != nullptr) {
+            output += buf.data();
+        }
+    }
+
+    int exit_code = 0;
+    subprocess_join(&proc, &exit_code);
+    done.store(true, std::memory_order_release);
+    watchdog.join();
+    subprocess_destroy(&proc);
+
+    if (exit_code != 0) {
+        SRV_WRN("query_gpu_devices: '%s --list-devices-json' exited with code %d\n", bin_path.c_str(), exit_code);
+        return {};
+    }
+
+    try {
+        return parse_gpu_devices_json(output);
+    } catch (const std::exception & e) {
+        SRV_WRN("query_gpu_devices: failed to parse device list JSON: %s\n", e.what());
+        return {};
+    }
+}
